# =============================================================
#  AGENDA QUICK — Modelo de Variaveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  Este arquivo SIM pode ser commitado — nao contem segredos.
# =============================================================

# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=agenda_quick
DB_USER=agenda_app
DB_PASSWORD=DEFINA_UMA_SENHA_FORTE_AQUI

DATABASE_URL=mysql+pymysql://agenda_app:DEFINA_UMA_SENHA_FORTE_AQUI@db:3306/agenda_quick

MYSQL_ROOT_PASSWORD=DEFINA_SENHA_ROOT_AQUI

# ─────────────────────────────────────────────
# AUTENTICACAO JWT
# ─────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GERE_UMA_CHAVE_HEX_64_CARACTERES_AQUI
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# AMBIENTE
# ─────────────────────────────────────────────
APP_ENV=development
DEBUG=true
